{
  "version": 2,
  "builds": [
    {
      "src": "kaasflow/backend/app.py",
      "use": "@vercel/python"
    },
    {
      "src": "kaasflow/frontend/**",
      "use": "@vercel/static"
    }
  ],
  "env": {
    "RAZORPAY_KEY_ID": "rzp_test_Ss58AcIHlslSdI",
    "RAZORPAY_KEY_SECRET": "tpJco5KKgp7YhoKpw7pD9zep"
  },
  "routes": [
    {
      "src": "/auth/(.*)",
      "dest": "/kaasflow/backend/app.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "/kaasflow/backend/app.py"
    },
    {
      "src": "/",
      "dest": "/kaasflow/frontend/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/kaasflow/frontend/$1"
    }
  ]
}