{
  "version": 2,
  "builds": [
    {
      "src": "kaasflow/backend/app.py",
      "use": "@vercel/python"
    },
    {
      "src": "kaasflow/frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/auth/(.*)",
      "dest": "/kaasflow/backend/app.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "/kaasflow/backend/app.py"
    },
    {
      "src": "/",
      "dest": "/kaasflow/frontend/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/kaasflow/frontend/$1"
    }
  ]
}