# Resend API Configuration
# Get your COMPLETE API key from: https://resend.com/api-keys
# The API key should be 40+ characters long
RESEND_API_KEY=

# From email address
# Option 1 (Recommended): Use onboarding@resend.dev (works immediately)
# Option 2: Use your verified domain (e.g., SamKass <welcome@samkass.site>)
RESEND_FROM_EMAIL=onboarding@resend.dev

# Push Notification VAPID Keys
# Generate these keys using: python -c "from pywebpush import webpush; print(webpush.generate_vapid_keys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=mailto:samkassfinance@gmail.com

# Instructions:
# 1. Copy this file to .env
# 2. Get your API key from https://resend.com/api-keys
# 3. Paste the COMPLETE key above
# 4. Generate VAPID keys for push notifications
# 5. Save the file
